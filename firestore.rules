rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. System Config: Only read by everyone (to check maintenance), write ONLY by admin
    match /system/config {
      allow read: if true;
      allow write: if false; // Must be done via Firebase Console or special Admin role
    }

    // 2. User Data: Only accessible by the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admin to read users for the dashboard
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 3. Requests & Notifications: Public write, Admin read/write
    match /requests/{requestId} {
      allow create: if true; // Let anyone request a movie
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // 4. Default: Lock everything else
    match /{document=**} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
