rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // EMERGENCY OPEN MODE (FIX FOR PERMISSION DENIED)
    // Allows any user (even guest) to read/write.
    // Use this to verify site functionality, then lock it down.
    
    match /{document=**} {
      allow read, write: if true; 
    }
  }
}
